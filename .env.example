# Copy this file to ".env" and fill in the values. Never commit ".env".

# Webhook signatures are verified (HMAC-SHA256). If a secret is blank, requests
# are REJECTED. Set true ONLY for local testing with unsigned tools; keep false
# in production and set real secrets.
ALLOW_UNSIGNED_WEBHOOKS=false

# Cal.com webhook signing secret (from the Cal.com webhook config)
CALCOM_WEBHOOK_SECRET=
# Cal.com API key (optional; only for outbound Cal.com calls)
CALCOM_API_KEY=

# Fireflies
FIREFLIES_WEBHOOK_SECRET=
FIREFLIES_API_KEY=
# Auto-fetch: seconds between pulling new transcripts (0 = off / webhook-only).
# 300 = every 5 minutes.
FIREFLIES_POLL_SECONDS=0

# Attio access token (Records read/write, Notes read/write,
# Object configuration read/write for auto-creating custom fields)
ATTIO_API_KEY=

# Claude (meeting analysis)
ANTHROPIC_API_KEY=
ANALYSIS_MODEL=claude-opus-4-8

# Internal team email domains (comma-separated); never treated as the client
INTERNAL_EMAIL_DOMAINS=deepsolv.com,deepsolv.ai

# true = also create a note for internal-only meetings (testing/demo);
# false = only client meetings are tracked (real product behavior)
TRACK_INTERNAL_MEETINGS=false

# Local server port
PORT=8000
